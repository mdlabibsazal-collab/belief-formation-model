fig2, ax = plt.subplots(figsize=(10, 6))

ax.plot(t, belief_strength_over_time(0.1, t), 'b-', linewidth=2, label='Low input (I=0.1)')
ax.plot(t, belief_strength_over_time(0.3, t), 'orange', linewidth=2, label='Medium input (I=0.3)')
